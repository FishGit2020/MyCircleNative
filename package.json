{
  "name": "mycircle-native",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "android:emulator": "emulator -avd Medium_Phone_API_36.1 -no-snapshot-load",
    "android:prebuild": "expo prebuild --platform android",
    "android:clean": "npx rimraf android && expo prebuild --platform android",
    "build:shared": "cd packages/shared && pnpm run build",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build:dev": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform android",
    "submit:android": "eas submit --platform android",
    "codegen": "graphql-codegen --config codegen.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "^3.12.11",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app-check": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "^55.0.0",
    "expo-audio": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image-picker": "~55.0.11",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-speech": "~55.0.8",
    "expo-speech-recognition": "^3.1.0",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "graphql": "^16.13.1",
    "nativewind": "^4.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/auth": "^23.8.6",
    "@react-native-firebase/firestore": "^23.8.6",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.57.0"
  }
}
