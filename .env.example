# MyCircleNative Environment Variables
# Copy this file to .env and fill in your values.

# GraphQL API endpoint (your Firebase Functions or Apollo Server URL)
GRAPHQL_ENDPOINT=https://your-project.cloudfunctions.net/graphql

# Firebase Configuration (configured via google-services.json / GoogleService-Info.plist)
# These are only needed if you use the JS SDK fallback:
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
